# Server
PORT=5000
NODE_ENV=development
FRONTEND_URL=http://localhost:5173

# Database
MONGODB_URI=mongodb+srv://user:pass@cluster.mongodb.net/client-hunter

# Auth (generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))")
JWT_SECRET=your_strong_random_secret_min_32_chars
JWT_EXPIRE=7d

# AI
GROQ_API_KEY=gsk_your_groq_api_key

# Email (Resend)
RESEND_API_KEY=re_your_resend_api_key
EMAIL_FROM=ClientHunter <hello@yourdomain.com>

# Daily Digest (optional - email address to receive daily report)
DIGEST_EMAIL=admin@yourdomain.com

# Lead Scraping (optional)
APIFY_API_TOKEN=apify_api_your_token

# Email Enrichment (optional)
HUNTER_API_KEY=your_hunter_io_api_key

# WhatsApp (optional)
WHATSAPP_API_TOKEN=your_meta_api_token
WHATSAPP_PHONE_ID=your_phone_number_id

# Slack Notifications (optional)
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/xxx/yyy/zzz
